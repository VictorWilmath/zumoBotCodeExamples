#include <Wire.h>
#include <Zumo32U4.h>

Zumo32U4LCD display;
Zumo32U4ButtonA buttonA;
Zumo32U4Motors motors;
Zumo32U4LineSensors lineSensors;
Zumo32U4ProximitySensors proxSensors;
Zumo32U4IMU imu;

// Constants
const uint16_t LINE_THRESHOLD = 1000; // Lower = more sensitive to white
const int16_t MAX_SPEED = 400;
const int16_t SEARCH_SPEED = 200;
const int32_t COLLISION_THRESHOLD = 5000; // Adjust based on testing

void setup() {
  // Initialize sensors
  lineSensors.initThreeSensors();
  proxSensors.initThreeSensors();
 
  Wire.begin();
  imu.init();
  imu.enableDefault();

  display.clear();
  display.print(F("Press A"));
  buttonA.waitForButton();
 
  // Standard 5-second Sumo delay
  delay(5000);
}

void loop() {
  // 1. READ SENSORS
  uint16_t lineValues[3];
  lineSensors.read(lineValues);
 
  proxSensors.read();
  uint8_t leftProx = proxSensors.countsLeftWithLeftLeds();
  uint8_t rightProx = proxSensors.countsRightWithRightLeds();
  uint8_t frontProx = proxSensors.countsFrontWithLeftLeds() + proxSensors.countsFrontWithRightLeds();

  imu.readAcc();
  int32_t xAcc = imu.a.x;
  int32_t yAcc = imu.a.y;

  // 2. LINE DETECTION (Priority 1)
  if (lineValues[0] < LINE_THRESHOLD) { // Left sensor saw white
    motors.setSpeeds(-MAX_SPEED, -MAX_SPEED);
    delay(200);
    motors.setSpeeds(MAX_SPEED, -MAX_SPEED);
    delay(300);
    return;
  }
  if (lineValues[2] < LINE_THRESHOLD) { // Right sensor saw white
    motors.setSpeeds(-MAX_SPEED, -MAX_SPEED);
    delay(200);
    motors.setSpeeds(-MAX_SPEED, MAX_SPEED);
    delay(300);
    return;
  }

  // 3. COLLISION DETECTION (Priority 2)
  // If we feel a hit (sudden acceleration spike)
  if (abs(xAcc) > COLLISION_THRESHOLD || abs(yAcc) > COLLISION_THRESHOLD) {
    display.clear();
    display.print(F("HIT!"));
    motors.setSpeeds(MAX_SPEED, MAX_SPEED); // Ram back or turn to face
    delay(100);
    return;
  }

  // 4. SEARCH AND ATTACK (Priority 3)
  if (frontProx >= 4) {
    // Opponent centered - Full charge
    motors.setSpeeds(MAX_SPEED, MAX_SPEED);
  }
  else if (leftProx > 2) {
    // Opponent to the left - Spin left
    motors.setSpeeds(-SEARCH_SPEED, SEARCH_SPEED);
  }
  else if (rightProx > 2) {
    // Opponent to the right - Spin right
    motors.setSpeeds(SEARCH_SPEED, -SEARCH_SPEED);
  }
  else {
    // No one found - Slow circle to scan
    motors.setSpeeds(SEARCH_SPEED, -SEARCH_SPEED);
  }
}
